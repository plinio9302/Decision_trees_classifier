   "cell_type": "code",
   "execution_count": null,
   "id": "cell-compare",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Calculate MSPE for all four models\n",
    "mspe_dt  = np.mean((y_test - y_pred_dt_tuned) ** 2)\n",
    "mspe_bag = np.mean((y_test - y_pred_bag) ** 2)\n",
    "mspe_rf  = np.mean((y_test - y_pred_rf_tuned) ** 2)\n",
    "mspe_nb  = np.mean((y_test - y_pred_nb_tuned) ** 2)\n",
    "\n",
    "print('=== Model Comparison ===')\n",
    "print(f'MSPE Decision Tree:  {mspe_dt:.4f}')\n",
    "print(f'MSPE Bagging:        {mspe_bag:.4f}')\n",
    "print(f'MSPE Random Forest:  {mspe_rf:.4f}')\n",
    "print(f'MSPE Naive Bayes:    {mspe_nb:.4f}')\n",
    "\n",
    "# Bar chart comparison\n",
    "models = ['Decision Tree\\n(Tuned)', 'Bagging', 'Random Forest\\n(Tuned)', 'Naive Bayes\\n(Tuned)']\n",
    "mspe_values = [mspe_dt, mspe_bag, mspe_rf, mspe_nb]\n",
    "colors = ['#e74c3c', '#3498db', '#2ecc71', '#9b59b6']\n",
    "\n",
    "plt.figure(figsize=(10, 6))\n",
    "bars = plt.bar(models, mspe_values, color=colors, edgecolor='black', linewidth=0.8)\n",
