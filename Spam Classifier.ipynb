   "id": "cell-feat",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Combine subject + body into a single text field\n",
    "train_df['text'] = train_df['subject'] + ' ' + train_df['body']\n",
    "test_df['text']  = test_df['subject']  + ' ' + test_df['body']\n",
