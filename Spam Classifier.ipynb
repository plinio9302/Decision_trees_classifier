    "mspe_dt  = np.mean((y_test - y_pred_dt_tuned) ** 2)\n",
    "mspe_bag = np.mean((y_test - y_pred_bag) ** 2)\n",
    "mspe_rf  = np.mean((y_test - y_pred_rf_tuned) ** 2)\n",
